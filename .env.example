# AI Agent Agency — Environment Configuration
# Copy this to .env and update paths for your project
#
# Usage:
#   bash:        source .env
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#
# Skills that read these vars: /doc-organize, /code-simplify, /agent-audit, /caveman

# ── Project paths ─────────────────────────────────────────────────────────────

# Root of your source project
PROJECT_ROOT=C:\Projects\my-project

# Agency repo root (standalone clone or submodule path)
AGENCY_DIR=${PROJECT_ROOT}\storage\agency

# ── Source directories ─────────────────────────────────────────────────────────

CSS_SRC_DIR=${PROJECT_ROOT}\src\assets\css
JS_SRC_DIR=${PROJECT_ROOT}\src\assets\js
DOCS_DIR=${PROJECT_ROOT}\docs

# ── Output / public directories ────────────────────────────────────────────────

PUBLIC_DIR=${PROJECT_ROOT}\public_html
RESOURCES_DIR=${PUBLIC_DIR}\resources

# ── Agent system ───────────────────────────────────────────────────────────────

# Agent profiles directory
AGENTS_DIR=${AGENCY_DIR}\agents

# MCP config — copy .vscode/mcp.example.json → .vscode/mcp.json and customize
# SSOT for all agent data, schedules, and universal rules
AGENT_CONFIG=${AGENCY_DIR}\.vscode\mcp.json

# Audit output directory (gitignored — generated per run)
AUDITS_DIR=${AGENCY_DIR}\audits

# Audit scripts directory
SCRIPTS_DIR=${PROJECT_ROOT}\scripts\audits
