{
  "editor.formatOnSave": false,

  "claude.contextFiles": [
    ".vscode/mcp.json",
    "agents/",
    "docs/WORKFLOW.md"
  ],

  "files.associations": {
    "*.md": "markdown"
  },

  "files.exclude": {
    ".foam/": true
  },

  "foam.openDailyNote.onVSCodeStartup": false,
  "foam.graph.style": {
    "background": "#1a1a2e",
    "edge": { "line": { "color": "#44475a" } }
  },
  "foam.files.ignore": [
    "audits/**",
    "generations/**",
    "agents/images/**"
  ]
}
