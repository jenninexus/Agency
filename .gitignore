# AI Agent Agency — .gitignore
# ==============================
# Framework for AI agent teams. Local customizations coexist with the public framework.

# ── Generated / runtime ──────────────────────────────────────────────────────

# Audit reports (generated locally per run)
audits/*.md
audits/*.log
!audits/.gitkeep

# Node
node_modules/
package-lock.json

# Logs
*.log
logs/

# ── Local config (customize from .example) ───────────────────────────────────

# Agent + MCP config — copy from mcp.example.json → mcp.json.
# Keep personal paths, private server names, local MCP env, and project-specific rosters out of Git.
mcp.json
.vscode/mcp.json
.config/

# Workspace — copy from agency.example.code-workspace
agency.code-workspace

# Environment vars (local paths and secrets)
.env
.env.local
.env.*.local

# ── Local-only tooling ────────────────────────────────────────────────────────

# Local agent roster dashboard (requires Live Server to run)
agents.html

# Local roadmap / planning docs — keep in docs/ but off public repo
# (docs/ in general IS tracked; only these specific planning files are local)
docs/ROADMAP.md
docs/PLANS.md
docs/NOTES.md

# Local Foam knowledge graph config
.foam/

# Claude Code session data
.claude/

# VS Code per-user overrides (copy *.example.json → the real file and customize)
.vscode/*.code-snippets
.vscode/launch.json
.vscode/settings.json

# ── Generated media (large binaries, local only) ─────────────────────────────

# Agent portrait output from generate-agent-portrait.ps1
generations/
agents/images/

# ── Private / personal content (local only) ──────────────────────────────────

# Detailed character prompt YAML — stays local (use .env + local copy)
agents/characters.yaml

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo
*.bak

# ── Project-specific agent directories (local only) ──────────────────────────

# Individual project dirs live locally — not published to the public repo.
# Only projects/README.md is tracked. Add your own projects/ subdirs locally.
projects/*/

# Archive directories (local only — never push)
archive/
_archive/

# ── TRACKED FILES (for reference) ────────────────────────────────────────────
# README.md, package.json, .env.example, .gitattributes
# .github/copilot-instructions.md
# mcp.example.json             ← public agent registry template (copy → mcp.json)
# .vscode/mcp.example.json     ← VS Code MCP server entry only (copy → .vscode/mcp.json)
# .vscode/settings.example.json
# agency.example.code-workspace
# agents/*.md  (characters.yaml is gitignored — keep local)
# projects/README.md  (concept doc only — project subdirs are local/gitignored)
# docs/, templates/, examples/, scripts/
# resources/images/banner.jpg
