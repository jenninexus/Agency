# AI Agent Agency — .gitignore
# ==============================
# Framework for AI agent teams. Local customizations coexist with the public framework.

# ── Generated / runtime ──────────────────────────────────────────────────────

# Audit reports (generated locally per run)
audits/*.md
audits/*.log
!audits/.gitkeep

# Node
node_modules/
package-lock.json

# Logs
*.log
logs/

# ── Local config (customize from .example) ───────────────────────────────────

# Agent config — copy from .config/mcp_agents.example.json and populate
.config/mcp_agents.json

# Workspace — copy from agency.example.code-workspace
agency.code-workspace

# Environment vars (local paths and secrets)
.env
.env.local
.env.*.local

# ── Local-only tooling ────────────────────────────────────────────────────────

# Local agent roster dashboard (requires Live Server to run)
agents.html

# Local Foam knowledge graph config
.foam/

# Claude Code session data
.claude/

# VS Code per-user overrides (copy settings.example.json → settings.json and customize)
.vscode/*.code-snippets
.vscode/launch.json
.vscode/settings.json

# ── Generated media (large binaries, local only) ─────────────────────────────

# Agent portrait output from generate-agent-portrait.ps1
generations/
agents/images/

# ── Private / personal content (local only) ──────────────────────────────────

# Detailed character prompt YAML — stays local (use .env + local copy)
agents/characters.yaml

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo
*.bak

# ── Project-specific local agents (private paths / credentials) ──────────────

# Uncomment to gitignore an entire project's agent directory if it contains
# private implementation details not suitable for the public repo:
# projects/jenninexus/storage/
# projects/martiangames/storage/
# projects/neophi/storage/

# ── TRACKED FILES (for reference) ────────────────────────────────────────────
# README.md, package.json
# .env.example, .gitattributes
# .config/mcp_agents.example.json
# .github/copilot-instructions.md
# .vscode/mcp.json, .vscode/settings.example.json
# agency.example.code-workspace
# agents/*.md  (characters.yaml is gitignored — keep local)
# projects/*/README.md, projects/neophi/Cipher.md
# docs/, templates/, examples/, scripts/
# resources/images/banner.jpg
