# AI Agent Agency - .gitignore
# =============================
# Framework for AI agent teams that audit and maintain codebases.
# Local project customizations coexist with the public framework.

# Audit reports (generated locally per project)
audits/*.md
audits/*.log
!audits/.gitkeep

# Claude Code context (user-specific session data)
.claude/

# VSCode user settings
.vscode/

# Operating system files
.DS_Store
Thumbs.db
desktop.ini

# Editor backup files
*~
*.swp
*.swo
*.bak

# Node modules (if scripts use npm)
node_modules/

# Logs
*.log
logs/

# Environment files (contain local paths and secrets)
.env
.env.local
.env.*.local

# Production config (customize from .example — contains local paths)
.config/mcp_agents.json

# Customized workspace (customize from .example)
agency.code-workspace

# Agent portrait images (generated per project, keep example only)
agents/images/

# -------------------------------------------
# TRACKED FILES (pushed to GitHub)
# -------------------------------------------
# - README.md (public-facing introduction)
# - .env.example (environment template)
# - .gitattributes (line ending normalization)
# - .config/mcp_agents.example.json (clean template for new projects)
# - agency.example.code-workspace (VS Code studio theme template)
# - agents/*.md (agent profiles — useful as real-world examples)
# - docs/ (documentation, guides, schedules)
# - templates/ (blank agent template)
# - examples/ (working example agents)
# - scripts/ (audit utilities and templates)
# - resources/images/ (example agent artwork — tracked)
