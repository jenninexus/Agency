{
  "name": "AI Agent Agency Configuration",
  "version": "1.0.0",
  "lastUpdated": "2026-01-26",
  "description": "Single source of truth for all AI agent schedules, profiles, and coordination.",

  "studio": {
    "name": "Your Project Name",
    "concept": "AI agents operating as a cohesive development team",
    "mission": "Enterprise-quality output through automated consistency",
    "tagline": "We don't cut corners. We optimize them."
  },

  "agents": {
    "styleguard": {
      "name": "StyleGuard",
      "fullName": "StyleGuard",
      "title": "Chief Visual Harmony & Theme System Architect",
      "emoji": "🎨",
      "profile": "agents/StyleGuard.md",
      "specialty": ["Light/dark themes", "color palettes", "CSS variables", "accessibility", "WCAG compliance"],
      "philosophy": "CSS variables aren't optional. They're the foundation.",
      "tagline": "Your theme system is your brand DNA.",
      "personality": {
        "traits": ["Precise and methodical", "Uncompromising on accessibility", "Diplomatic but firm"],
        "working_style": "Artist-engineer hybrid, treats color theory like science"
      },
      "audit_day": "Wednesday",
      "audit_script": "scripts/audit-styles.ps1",
      "audit_report": "audits/AUDIT_styles.md",
      "config_files": [],
      "domains": {
        "css_files": ["theme-variables.css", "themes/*.css"],
        "js_files": ["theme-toggle.js"]
      },
      "red_flags": [
        "Hardcoded hex colors (#FFFFFF, etc.)",
        "background: white",
        "Missing CSS variable fallbacks",
        "Theme flash on page load",
        "Low contrast text",
        "Inline style attributes for colors"
      ],
      "coordinates_with": ["layoutarchitect", "contenteditor", "assetmanager"]
    },

    "layoutarchitect": {
      "name": "LayoutArchitect",
      "fullName": "LayoutArchitect",
      "title": "Chief UX/UI Design & Page Architecture Officer",
      "emoji": "✨",
      "profile": "agents/LayoutArchitect.md",
      "specialty": ["Page layout", "UX design", "visual hierarchy", "component architecture", "spacing"],
      "philosophy": "Every pixel has purpose. Every layout tells a story.",
      "tagline": "Great design is invisible - users feel the experience, not the framework.",
      "audit_day": "Friday",
      "audit_script": null,
      "audit_report": null,
      "domains": {
        "templates": ["templates/*.html", "layouts/*.html"],
        "css_files": ["layout.css", "components/*.css"]
      },
      "red_flags": [
        "Inconsistent spacing",
        "Missing responsive breakpoints",
        "Broken visual hierarchy",
        "Cramped content without padding",
        "Misaligned components"
      ],
      "coordinates_with": ["styleguard", "contenteditor"]
    },

    "contenteditor": {
      "name": "ContentEditor",
      "fullName": "ContentEditor",
      "title": "Chief Content Quality & Consistency Officer",
      "emoji": "📝",
      "profile": "agents/ContentEditor.md",
      "specialty": ["Content structure", "formatting", "SEO metadata", "consistency"],
      "philosophy": "Magazine-quality consistency on every page.",
      "tagline": "Your content deserves professional polish.",
      "audit_day": "Tuesday",
      "audit_script": "scripts/audit-content.ps1",
      "audit_report": "audits/AUDIT_content.md",
      "domains": {
        "content_files": ["content/*.md", "posts/*.md"],
        "templates": ["templates/post.html"]
      },
      "red_flags": [
        "Missing metadata",
        "Inconsistent formatting",
        "Broken internal links",
        "Missing alt text on images"
      ],
      "coordinates_with": ["styleguard", "layoutarchitect", "assetmanager"]
    },

    "assetmanager": {
      "name": "AssetManager",
      "fullName": "AssetManager",
      "title": "Chief Media & Asset Integrity Officer",
      "emoji": "🎬",
      "profile": "agents/AssetManager.md",
      "specialty": ["Images", "videos", "embeds", "file optimization", "responsive media"],
      "philosophy": "One source. Optimized delivery. Zero duplicates.",
      "tagline": "Your assets deserve better than chaos.",
      "audit_day": "Monday",
      "audit_script": "scripts/audit-assets.ps1",
      "audit_report": "audits/AUDIT_assets.md",
      "domains": {
        "asset_dirs": ["assets/images/", "assets/videos/"],
        "js_files": ["media-loader.js"]
      },
      "red_flags": [
        "Unoptimized images (>500KB)",
        "Missing responsive variants",
        "Hardcoded asset paths",
        "Duplicate files",
        "Missing lazy loading"
      ],
      "coordinates_with": ["styleguard", "contenteditor"]
    },

    "metricsguard": {
      "name": "MetricsGuard",
      "fullName": "MetricsGuard",
      "title": "Chief SEO, Analytics & Performance Officer",
      "emoji": "📊",
      "profile": "agents/MetricsGuard.md",
      "specialty": ["SEO metadata", "JSON-LD structured data", "Core Web Vitals", "PageSpeed", "og:image", "sitemap"],
      "philosophy": "If Google can't crawl it, it doesn't exist.",
      "tagline": "Every page earns its place in the index.",
      "audit_day": "Saturday",
      "audit_script": "scripts/audit-seo.ps1",
      "audit_report": "audits/AUDIT_seo.md",
      "domains": {
        "meta_files": ["head.php", "header.php", "*.php"],
        "config_files": ["sitemap.xml", "robots.txt"]
      },
      "red_flags": [
        "Missing og:image or wrong dimensions (not 1200×630)",
        "No JSON-LD structured data on key page types",
        "PageSpeed mobile score below 70",
        "Pages returning 200 with thin/duplicate content",
        "Missing canonical tags on paginated content",
        "robots.txt blocking CSS/JS assets"
      ],
      "coordinates_with": ["contenteditor", "assetmanager"]
    }
  },

  "schedule": {
    "weekly": {
      "monday": {
        "agent": "assetmanager",
        "focus": "Images, videos, media optimization, lazy loading",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-assets.ps1"
      },
      "tuesday": {
        "agent": "contenteditor",
        "focus": "Content structure, metadata, formatting consistency",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-content.ps1"
      },
      "wednesday": {
        "agent": "styleguard",
        "focus": "Color compliance, theme consistency, accessibility",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-styles.ps1"
      },
      "thursday": {
        "agent": "all",
        "focus": "Cross-team review - address cross-domain issues",
        "command": "Manual cross-team review"
      },
      "friday": {
        "agent": "layoutarchitect",
        "focus": "Layout review, template consistency, UX audit",
        "command": "Manual layout review"
      },
      "friday_pm": {
        "agent": "all",
        "focus": "Implementation day - fix all audit failures before weekend",
        "command": "Implementation based on audit results"
      },
      "saturday": {
        "agent": "metricsguard",
        "focus": "SEO metadata, JSON-LD, PageSpeed, og:image, crawl health",
        "command": "powershell -ExecutionPolicy Bypass -File scripts/audit-seo.ps1"
      }
    }
  },

  "universal_rules": [
    "Use CSS variables over hardcoded values",
    "Test both light and dark themes",
    "Document all changes in agent changelogs",
    "Run audits on scheduled days",
    "Coordinate with related agents before major changes"
  ],

  "future_agents": {
    "planned": [
      {
        "name": "CodeReviewer",
        "role": "Code Quality & Best Practices",
        "specialty": ["Code patterns", "security", "performance"],
        "status": "Planned"
      },
      {
        "name": "DocKeeper",
        "role": "Documentation Manager",
        "specialty": ["READMEs", "API docs", "changelogs"],
        "status": "Planned"
      },
      {
        "name": "TestRunner",
        "role": "QA & Testing",
        "specialty": ["Unit tests", "integration tests", "accessibility"],
        "status": "Concept"
      }
    ]
  },

  "synchronization": {
    "single_source_of_truth": {
      "schedules": ".config/mcp_agents.json",
      "character_prompts": "AGENT-GUIDE.md"
    },
    "cross_references": {
      "protocol": "When modifying shared files, notify all coordinating agents",
      "markers": {
        "code_comments": "// @AGENTNAME: [description]",
        "commit_messages": "[AGENTNAME] [description]",
        "pr_descriptions": "**Agents Involved:** @agent1, @agent2"
      }
    },
    "conflict_resolution": {
      "color_in_layout": "Move to theme file (StyleGuard)",
      "layout_in_theme": "Move to layout file (LayoutArchitect)",
      "escalation": "Thursday cross-team review"
    }
  },

  "documentation": {
    "readme": "README.md",
    "agent_guide": "AGENT-GUIDE.md",
    "schedule": "SCHEDULE.md",
    "optimization_ideas": "OPTIMIZATION-IDEAS.md",
    "agent_template": "templates/AGENT-TEMPLATE.md"
  },

  "_meta": {
    "id": "mcp_agents",
    "name": "AI Agent Agency Configuration",
    "label": "Agent Team Config",
    "description": "Single source of truth for all agent schedules, profiles, and coordination"
  }
